# ConsultApp na VPS Contabo
NODE_ENV=production
HOST=127.0.0.1
PORT=5173

# Banco PostgreSQL local da VPS
DB_BACKEND=postgres
DB_NAME=consultappdb
DB_USER=consultapp
DB_PASSWORD=troque-esta-senha-forte
DB_HOST=127.0.0.1
DB_PORT=5432
PGSSL=false

# URL publica usada em links de PDF, WhatsApp e e-mail
PUBLIC_APP_URL=https://gamadeveloper.com.br
COOKIE_SECURE=true

# Usuario tecnico inicial
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha
ADMIN_EMAIL=admin@gamadeveloper.com.br

# Convidado
GUEST_USER=convidado
GUEST_PASSWORD=convidado123
GUEST_EMAIL=convidado@gamadeveloper.com.br

# SMTP, se preferir configurar por variaveis em vez de smtp-config.json
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=Consult

# Backup externo em Cloudflare R2
# Crie um bucket privado e uma chave R2 com permissao de leitura/escrita.
R2_ENABLED=false
R2_ACCOUNT_ID=
R2_BUCKET=consultapp-backups
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PREFIX=consultapp/producao
# Opcional. Se vazio, usa https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=
