# Banco de dados PostgreSQL local
DB_NAME=consultappdb
DB_USER=postgres
DB_PASSWORD=adminPostgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Alternativa util em hospedagem remota
# DATABASE_URL=postgresql://postgres:adminPostgres@127.0.0.1:5432/consultappdb
PGSSL=false
# Em hospedagem com TLS e certificado gerenciado, ajuste conforme o provedor.
